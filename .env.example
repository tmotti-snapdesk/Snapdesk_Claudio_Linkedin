# Copie ces variables dans Vercel → Project → Settings → Environment Variables
# (et localement dans un fichier .env si tu utilises `vercel dev`)

# Clé API Anthropic (https://console.anthropic.com/ → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Secret partagé entre le Google Sheet (Apps Script) et ce backend.
# Mets une longue chaîne aléatoire. La MÊME valeur doit être saisie côté Apps Script
# (menu "Snapdesk LinkedIn" → "🔑 Définir le secret API").
API_SECRET=change-moi-par-une-longue-chaine-aleatoire

# Optionnel : modèle Claude à utiliser (défaut : claude-sonnet-5)
# MODEL=claude-sonnet-5
